# Application
NODE_ENV=development
PORT=3000
APP_NAME=DocManager

# Database
DATABASE_URL=postgresql://docmanager:docmanager123@localhost:5432/docmanager_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_this_to_a_very_long_random_secret_in_production_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_also_very_long_min_64_chars
JWT_REFRESH_EXPIRES_IN=7d

# MinIO (Phase 2)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=docmanager
MINIO_USE_SSL=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Seed
MASTER_COMPANY_NAME=Master Company
MASTER_ADMIN_EMAIL=admin@docmanager.com
MASTER_ADMIN_PASSWORD=Admin@123456
